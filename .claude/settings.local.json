{
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(/opt/homebrew/bin/npm --version)",
      "Bash(export PATH=\"/opt/homebrew/bin:$PATH\")",
      "Bash(/opt/homebrew/bin/npm install *)",
      "Bash(/opt/homebrew/bin/npx next *)",
      "Bash(echo \"PID: $!\")",
      "Bash(curl -sf http://localhost:3000 -o /dev/null)",
      "Bash(open -a \"Google Chrome\" \"http://localhost:3000\")",
      "Bash(lsof -ti:3000)",
      "Bash(xargs kill *)",
      "Bash(disown)",
      "Bash(echo \"started PID $!\")",
      "Bash(open -a \"Google Chrome\" \"http://localhost:3000/onboarding\")",
      "Bash(open -a \"Google Chrome\" \"http://localhost:3000/today\")",
      "Bash(open -a \"Google Chrome\" \"http://localhost:3000/login\")",
      "Bash(open -a \"Google Chrome\" \"http://localhost:3000/gastos\")"
    ]
  }
}
